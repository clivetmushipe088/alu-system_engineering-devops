#!/usr/bin/env bash
# Configures a new Ubuntu machine with Nginx and a custom HTTP response header
# Header: X-Served-By: <hostname>
# shellcheck disable=SC2154

# Update package list and install Nginx
apt-get update -y
apt-get install -y nginx

# Get the hostname of the current server
HOSTNAME=$(hostname)

# Configure the custom header in the Nginx default site
# Insert the header into the server block using sed
sed -i "s/server_name _;/server_name _;\n\tadd_header X-Served-By $HOSTNAME;/" /etc/nginx/sites-available/default

# Ensure Nginx is enabled and restarted
service nginx restart

