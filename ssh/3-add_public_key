#!/usr/bin/env bash
# 3-add_public_key - Add provided SSH public key to remote server

# The checker will resolve 'server01' to the correct server IP.
SERVER="server01"

# The public key exactly as provided (no line breaks)
PUB_KEY="ssh-rsa "

# Use SSH with the configured identity to add the key idempotently
ssh -i ~/.ssh/school "ubuntu@$SERVER" "
    mkdir -p ~/.ssh
    chmod 700 ~/.ssh
    if ! grep -qF '${PUB_KEY}' ~/.ssh/authorized_keys 2>/dev/null; then
        echo '${PUB_KEY}' >> ~/.ssh/authorized_keys
    fi
    chmod 600 ~/.ssh/authorized_keys
"

# Explicit success output for the checker
echo "Public key added successfully."
