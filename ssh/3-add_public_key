#!/usr/bin/env bash
# 3-add_public_key - Add provided SSH public key to remote server

# Set the server IP or hostname (change to your server's IP)
SERVER="server01"

# The public key to add (provided in the task)
PUB_KEY="ssh-rsa "

# Use SSH to add the key (creates .ssh directory if missing and appends key)
ssh -i ~/.ssh/school "ubuntu@$SERVER" "mkdir -p ~/.ssh && echo '$PUB_KEY' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys && chmod 700 ~/.ssh"
