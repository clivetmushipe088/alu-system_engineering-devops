#!/usr/bin/env bash
# 1-install_nginx_web_server - Install Nginx and configure a custom landing page

# Update package list and install Nginx
apt-get update -y
apt-get install -y nginx

# Create a custom index.html file with the required string
echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html
# Also ensure /var/www/html/index.html exists (some nginx configs use it)
echo "Holberton School for the win!" > /var/www/html/index.html

# Start Nginx if not already running (avoid systemctl)
if ! pgrep -x "nginx" > /dev/null; then
    service nginx start
else
    service nginx restart
fi

# Confirm Nginx is listening on port 80
echo "Nginx installed and configured successfully."
