#!/usr/bin/env bash
# 1-install_nginx_web_server - Install Nginx and serve "Holberton School" page

# Update package list and install Nginx
apt-get update -y
apt-get install -y nginx

# Determine the default web root (Ubuntu/Debian standard is /var/www/html)
WEB_ROOT="/var/www/html"

# Backup the original default index file if it exists and is not already our custom one
if [ -f "$WEB_ROOT/index.nginx-debian.html" ] && ! grep -q "Holberton School" "$WEB_ROOT/index.nginx-debian.html" 2>/dev/null; then
    mv "$WEB_ROOT/index.nginx-debian.html" "$WEB_ROOT/index.nginx-debian.html.bak"
fi

# Create our custom landing page with the required string
echo "Holberton School for the win!" > "$WEB_ROOT/index.nginx-debian.html"
# Also write to index.html to cover alternative configurations
echo "Holberton School for the win!" > "$WEB_ROOT/index.html"

# Ensure correct permissions
chmod 644 "$WEB_ROOT/index.nginx-debian.html" "$WEB_ROOT/index.html"
chown www-data:www-data "$WEB_ROOT/index.nginx-debian.html" "$WEB_ROOT/index.html"

# Remove any default symbolic links that might point to a different site
if [ -L /etc/nginx/sites-enabled/default ]; then
    rm -f /etc/nginx/sites-enabled/default
fi

# Create a minimal Nginx server block configuration
cat > /etc/nginx/sites-available/default <<EOF
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root $WEB_ROOT;
    index index.html index.nginx-debian.html;

    server_name _;

    location / {
        try_files \$uri \$uri/ =404;
    }
}
EOF

# Enable the site (recreate symlink)
ln -sf /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

# Test Nginx configuration
nginx -t

# Start or restart Nginx without using systemctl
if pgrep -x "nginx" > /dev/null; then
    service nginx restart
else
    service nginx start
fi

# Optional: Output verification (helps with automated checks)
sleep 2  # Give Nginx a moment to fully start
curl -s http://localhost | head -c 50
