#!/usr/bin/env bash
# Configures Nginx server with a 301 redirect for /redirect_me

# Update package list and install Nginx
apt-get update
apt-get install -y nginx

# Add redirect configuration to the default server block
# Using sed to insert the location block after the server_name directive
sudo sed -i "/server_name _;/a\\
\\
\tlocation /redirect_me {\\
\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\\
\t}" /etc/nginx/sites-available/default

# Restart Nginx to apply changes
service nginx restart

